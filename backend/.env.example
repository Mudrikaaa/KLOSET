# Server Port
PORT=5000

# PostgreSQL Local Connection URL
# Replace username, password, and kloset_db with your local PG details
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kloset_db

# JWT Signature Key (Any random long string)
JWT_SECRET=your_jwt_super_secret_signing_key_here

# Cloudinary Integration API Credentials
# Get these from your Cloudinary dashboard settings
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Gemini API key for garment auto-detection (free tier: https://aistudio.google.com/apikey)
# Optional — if unset, the app simply skips AI pre-fill and users tag garments manually.
GEMINI_API_KEY=your_gemini_api_key
# Optional override of the vision model (defaults to gemini-3.5-flash — the
# current free-tier flash model; older 2.x free tiers are retired)
# GEMINI_MODEL=gemini-3.5-flash

# Self-hosted ML service (rembg + SegFormer) for garment cutouts.
# Optional — if unreachable, uploads still save with the original photo only.
ML_SERVICE_URL=http://localhost:8001

# Node Environment ('development' or 'production')
NODE_ENV=development

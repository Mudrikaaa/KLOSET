# Server Port
PORT=5000

# PostgreSQL Local Connection URL
# Replace username, password, and kloset_db with your local PG details
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kloset_db

# JWT Signature Key (Any random long string)
JWT_SECRET=your_jwt_super_secret_signing_key_here

# Cloudinary Integration API Credentials
# Get these from your Cloudinary dashboard settings
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Node Environment ('development' or 'production')
NODE_ENV=development
